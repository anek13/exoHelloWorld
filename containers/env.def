Bootstrap: docker
From: python:3.13-slim

%files
    pyproject.toml /app/
    src/ /app/src/
    LICENSE /app/
    README.md /app/

%post
    cd /app
    pip install uv
    uv venv /opt/venv
    
    export SETUPTOOLS_SCM_PRETEND_VERSION="0.0.0"
    
    VIRTUAL_ENV=/opt/venv uv sync --active

%environment
    export PATH="/opt/venv/bin:$PATH"
    export UV_NO_SYNC=1
    export UV_FROZEN=1