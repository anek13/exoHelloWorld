Bootstrap: docker
From: python:3.13-slim

# --- NEW: Define arguments that can be passed in during the build ---
%arguments
    VERSION=0.0.0

%files
    pyproject.toml /app/
    src/ /app/src/
    LICENSE /app/
    README.md /app/

%post
    cd /app
    pip install uv
    uv venv /opt/venv
    
    # --- UPDATED: Inject the VERSION argument we passed in ---
    export SETUPTOOLS_SCM_PRETEND_VERSION="{{ VERSION }}"
    
    VIRTUAL_ENV=/opt/venv uv sync --active

%environment
    export PATH="/opt/venv/bin:$PATH"
    export UV_NO_SYNC=1
    export UV_FROZEN=1